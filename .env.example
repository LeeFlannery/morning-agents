# Copy this file to .env and fill in your values.
# cp .env.example .env

# Anthropic API key (required)
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# GitHub personal access token (required for PR Queue agent)
# Needs: repo, read:org -- create one at https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# Your GitHub username (required for PR Queue agent)
GITHUB_USERNAME=your-github-username
